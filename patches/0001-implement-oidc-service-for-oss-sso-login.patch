+func TestClaimsFromIDToken(t *testing.T) {
+	svc := &ossOIDCService{}
+
+	t.Run("all standard claims present", func(t *testing.T) {
+		idClaims := &oidc.IDTokenClaims{
+			TokenClaims: oidc.TokenClaims{
+				Subject: "sub-123",
+			},
+		}
+		idClaims.PreferredUsername = "alice"
+		idClaims.Email = "alice@example.com"
+		idClaims.Name = "Alice Smith"
+		idClaims.Claims = map[string]any{
+			"groups": []any{"admin", "users"},
+		}
+
+		claims := svc.claimsFromIDToken(idClaims)
+
+		assert.Equal(t, []string{"sub-123"}, claims["sub"])
+		assert.Equal(t, []string{"alice"}, claims["preferred_username"])
+		assert.Equal(t, []string{"alice@example.com"}, claims["email"])
+		assert.Equal(t, []string{"Alice Smith"}, claims["name"])
+		assert.Equal(t, []string{"admin", "users"}, claims["groups"])
+	})
+
+	t.Run("only subject", func(t *testing.T) {
+		idClaims := &oidc.IDTokenClaims{
+			TokenClaims: oidc.TokenClaims{
+				Subject: "sub-456",
+			},
+		}
+
+		claims := svc.claimsFromIDToken(idClaims)
+
+		assert.Equal(t, []string{"sub-456"}, claims["sub"])
+		assert.NotContains(t, claims, "preferred_username")
+		assert.NotContains(t, claims, "email")
+		assert.NotContains(t, claims, "name")
+	})
+
+	t.Run("custom claims included", func(t *testing.T) {
+		idClaims := &oidc.IDTokenClaims{
+			TokenClaims: oidc.TokenClaims{
+				Subject: "sub-789",
+			},
+		}
+		idClaims.Claims = map[string]any{
+			"department": "engineering",
+			"team":       []any{"backend", "infra"},
+		}
+
+		claims := svc.claimsFromIDToken(idClaims)
+
+		assert.Equal(t, []string{"engineering"}, claims["department"])
+		assert.Equal(t, []string{"backend", "infra"}, claims["team"])
+	})
+
+	t.Run("empty subject omitted", func(t *testing.T) {
+		idClaims := &oidc.IDTokenClaims{}
+		claims := svc.claimsFromIDToken(idClaims)
+		assert.NotContains(t, claims, "sub")
+	})
+}
