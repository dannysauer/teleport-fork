+func TestClaimValueToStringSlice(t *testing.T) {
+	tests := []struct {
+		name string
+		in   any
+		want []string
+	}{
+		{name: "string", in: "alice", want: []string{"alice"}},
+		{name: "[]string", in: []string{"a", "b"}, want: []string{"a", "b"}},
+		{name: "[]any strings", in: []any{"x", "y"}, want: []string{"x", "y"}},
+		{name: "[]any mixed", in: []any{"a", 42}, want: []string{"a", "42"}},
+		{name: "int", in: 7, want: []string{"7"}},
+		{name: "bool", in: true, want: []string{"true"}},
+		{name: "float64", in: 3.14, want: []string{"3.14"}},
+	}
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			got := claimValueToStringSlice(tt.in)
+			assert.Equal(t, tt.want, got)
+		})
+	}
+}
