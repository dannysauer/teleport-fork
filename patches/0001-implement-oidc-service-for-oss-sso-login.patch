+func TestExtractUsername(t *testing.T) {
+	svc := &ossOIDCService{}
+
+	t.Run("custom username_claim", func(t *testing.T) {
+		conn := newTestOIDCConnector(t, "custom", types.OIDCConnectorSpecV3{
+			IssuerURL:     "https://example.com",
+			ClientID:      "id",
+			ClientSecret:  "secret",
+			RedirectURLs:  []string{"https://proxy.example.com/v1/webapi/oidc/callback"},
+			ClaimsToRoles: []types.ClaimMapping{{Claim: "groups", Value: "*", Roles: []string{"access"}}},
+			UsernameClaim: "nickname",
+		})
+		claims := map[string][]string{
+			"sub":                {"sub-123"},
+			"preferred_username": {"alice"},
+			"email":              {"alice@example.com"},
+			"nickname":           {"coolalice"},
+		}
+		assert.Equal(t, "coolalice", svc.extractUsername(conn, claims))
+	})
+
+	t.Run("custom claim missing falls through to preferred_username", func(t *testing.T) {
+		conn := newTestOIDCConnector(t, "missing-custom", types.OIDCConnectorSpecV3{
+			IssuerURL:     "https://example.com",
+			ClientID:      "id",
+			ClientSecret:  "secret",
+			RedirectURLs:  []string{"https://proxy.example.com/v1/webapi/oidc/callback"},
+			ClaimsToRoles: []types.ClaimMapping{{Claim: "groups", Value: "*", Roles: []string{"access"}}},
+			UsernameClaim: "nickname",
+		})
+		claims := map[string][]string{
+			"sub":                {"sub-123"},
+			"preferred_username": {"alice"},
+			"email":              {"alice@example.com"},
+		}
+		assert.Equal(t, "alice", svc.extractUsername(conn, claims))
+	})
+
+	t.Run("fallback preferred_username", func(t *testing.T) {
+		conn := newTestOIDCConnector(t, "no-claim", types.OIDCConnectorSpecV3{
+			IssuerURL:     "https://example.com",
+			ClientID:      "id",
+			ClientSecret:  "secret",
+			RedirectURLs:  []string{"https://proxy.example.com/v1/webapi/oidc/callback"},
+			ClaimsToRoles: []types.ClaimMapping{{Claim: "groups", Value: "*", Roles: []string{"access"}}},
+		})
+		claims := map[string][]string{
+			"sub":                {"sub-123"},
+			"preferred_username": {"alice"},
+			"email":              {"alice@example.com"},
+		}
+		assert.Equal(t, "alice", svc.extractUsername(conn, claims))
+	})
+
+	t.Run("fallback email when preferred_username missing", func(t *testing.T) {
+		conn := newTestOIDCConnector(t, "email-fallback", types.OIDCConnectorSpecV3{
+			IssuerURL:     "https://example.com",
+			ClientID:      "id",
+			ClientSecret:  "secret",
+			RedirectURLs:  []string{"https://proxy.example.com/v1/webapi/oidc/callback"},
+			ClaimsToRoles: []types.ClaimMapping{{Claim: "groups", Value: "*", Roles: []string{"access"}}},
+		})
+		claims := map[string][]string{
+			"sub":   {"sub-123"},
+			"email": {"alice@example.com"},
+		}
+		assert.Equal(t, "alice@example.com", svc.extractUsername(conn, claims))
+	})
+
+	t.Run("fallback sub when all else missing", func(t *testing.T) {
+		conn := newTestOIDCConnector(t, "sub-fallback", types.OIDCConnectorSpecV3{
+			IssuerURL:     "https://example.com",
+			ClientID:      "id",
+			ClientSecret:  "secret",
+			RedirectURLs:  []string{"https://proxy.example.com/v1/webapi/oidc/callback"},
+			ClaimsToRoles: []types.ClaimMapping{{Claim: "groups", Value: "*", Roles: []string{"access"}}},
+		})
+		claims := map[string][]string{
+			"sub": {"sub-123"},
+		}
+		assert.Equal(t, "sub-123", svc.extractUsername(conn, claims))
+	})
+
+	t.Run("empty claims returns empty string", func(t *testing.T) {
+		conn := newTestOIDCConnector(t, "empty", types.OIDCConnectorSpecV3{
+			IssuerURL:     "https://example.com",
+			ClientID:      "id",
+			ClientSecret:  "secret",
+			RedirectURLs:  []string{"https://proxy.example.com/v1/webapi/oidc/callback"},
+			ClaimsToRoles: []types.ClaimMapping{{Claim: "groups", Value: "*", Roles: []string{"access"}}},
+		})
+		assert.Equal(t, "", svc.extractUsername(conn, map[string][]string{}))
+	})
+}
