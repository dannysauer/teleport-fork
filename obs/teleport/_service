<services>
  <!--
    Fetch Teleport source from the fork's obs-build-source branch.
    prep-obs-source.yml force-updates that branch to the exact upstream stable
    tag that produced the build-assets release, so the source and prebuilt
    assets stay tied to the same release identity. Stable Teleport releases are
    tagged on upstream release branches, not necessarily on master; the sync
    workflow detects the newest clean vX.Y.Z tag across all upstream tags.

    This service is triggered by prep-obs-source.yml (via OBS trigger token)
    after it has updated obs-build-source and uploaded fresh build assets.
    No manual _service edits are needed between versions.
  -->
  <service name="tar_scm">
    <param name="url">https://github.com/dannysauer/teleport-fork</param>
    <param name="scm">git</param>
    <param name="revision">obs-build-source</param>
    <param name="submodules">disable</param>
    <param name="versionformat">@PARENT_TAG@</param>
    <param name="match-tag">v*</param>
    <param name="versionrewrite-pattern">v([0-9]+\.[0-9]+\.[0-9]+).*</param>
    <param name="versionrewrite-replacement">\1</param>
    <param name="exclude">.git</param>
    <param name="exclude">e</param>
    <param name="exclude">e2e</param>
    <param name="exclude">rfd</param>
    <param name="exclude">docs</param>
    <param name="filename">teleport</param>
  </service>

  <!--
    Fetch packaging files from the obs-build-inputs branch and extract them
    directly into the OBS package source directory.  This means only
    _service itself needs to be uploaded to OBS to bootstrap a package.
    The spec and debian.* files are pinned to the same autobuild commit that
    produced the downloaded build-assets release.
  -->
  <service name="obs_scm">
    <param name="url">https://github.com/dannysauer/teleport-fork</param>
    <param name="scm">git</param>
    <param name="revision">obs-build-inputs</param>
    <param name="subdir">obs/teleport</param>
    <param name="filename">packaging</param>
    <param name="extract">teleport.spec</param>
    <param name="extract">debian.*</param>
  </service>

  <!--
    Fetch patch files from the obs-build-inputs branch patches/ directory.
    These are applied in sorted filename order by the spec and debian/rules.
  -->
  <service name="obs_scm">
    <param name="url">https://github.com/dannysauer/teleport-fork</param>
    <param name="scm">git</param>
    <param name="revision">obs-build-inputs</param>
    <param name="subdir">patches</param>
    <param name="filename">patches</param>
    <param name="extract">*.patch</param>
  </service>

  <!--
    Vendor all Go module dependencies.
    Runs during the OBS service phase (which has network access).
    Result is a vendor/ directory added to the source tarball.
  -->
  <service name="recompress">
    <param name="file">teleport*.tar</param>
    <param name="compression">gz</param>
  </service>

  <service name="go_modules">
    <param name="archive">teleport*.tar.gz</param>
  </service>

  <!-- Update spec Version: and debian changelog from the extracted git tag. -->
  <service name="set_version">
    <param name="basename">teleport</param>
  </service>

  <!--
    The following assets are fetched from the persistent "build-assets" release
    in the GitHub fork. prep-obs-source.yml overwrites these files in-place each
    time a new upstream tag is processed, so these URLs never need to change.
  -->

  <!-- Pre-built web assets (Node/pnpm build, not available in OBS) -->
  <service name="download_url">
    <param name="host">github.com</param>
    <param name="protocol">https</param>
    <param name="path">/dannysauer/teleport-fork/releases/download/build-assets/teleport-webassets.tar.gz</param>
  </service>

  <!-- Manifest and checksums for the stable build-assets release files. -->
  <service name="download_url">
    <param name="host">github.com</param>
    <param name="protocol">https</param>
    <param name="path">/dannysauer/teleport-fork/releases/download/build-assets/teleport-build-assets.env</param>
  </service>
  <service name="download_url">
    <param name="host">github.com</param>
    <param name="protocol">https</param>
    <param name="path">/dannysauer/teleport-fork/releases/download/build-assets/teleport-build-assets.sha256</param>
  </service>

  <!-- Pre-vendored Rust deps for fdpass-teleport (tool/fdpass-teleport/vendor/) -->
  <service name="download_url">
    <param name="host">github.com</param>
    <param name="protocol">https</param>
    <param name="path">/dannysauer/teleport-fork/releases/download/build-assets/teleport-fdpass-vendor.tar.gz</param>
  </service>

  <!--
    Pre-built fdpass-teleport binaries for Ubuntu 24.04.
    Ubuntu 24.04 ships Rust 1.75 which is too old; Tumbleweed builds from source.
  -->
  <service name="download_url">
    <param name="host">github.com</param>
    <param name="protocol">https</param>
    <param name="path">/dannysauer/teleport-fork/releases/download/build-assets/fdpass-teleport-linux-amd64</param>
  </service>
  <service name="download_url">
    <param name="host">github.com</param>
    <param name="protocol">https</param>
    <param name="path">/dannysauer/teleport-fork/releases/download/build-assets/fdpass-teleport-linux-arm64</param>
  </service>

  <!--
    Go 1.25 toolchain tarballs for Ubuntu 24.04 builds.
    Ubuntu 24.04's packaged Go (1.22) is too old for Teleport 19.
    prep-obs-source.yml reads build.assets/versions.mk and publishes the
    matching Go tarballs with these stable asset names.
  -->
  <service name="download_url">
    <param name="host">github.com</param>
    <param name="protocol">https</param>
    <param name="path">/dannysauer/teleport-fork/releases/download/build-assets/teleport-go-linux-amd64.tar.gz</param>
  </service>
  <service name="download_url">
    <param name="host">github.com</param>
    <param name="protocol">https</param>
    <param name="path">/dannysauer/teleport-fork/releases/download/build-assets/teleport-go-linux-arm64.tar.gz</param>
  </service>
</services>
